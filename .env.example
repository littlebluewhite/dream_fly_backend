# Application
# Selects which config/{APP_ENV}.toml overlay is loaded on top of
# config/default.toml. Valid values: development, production.
APP_ENV=development

# Server
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=3000
# Comma-separated allowed origins (empty = allow all, for dev only)
APP__SERVER__ALLOWED_ORIGINS=
# Trust `X-Forwarded-For` / `X-Real-IP` for client-IP extraction. Enable ONLY
# when this server sits behind a reverse proxy that strips/rewrites these
# headers for untrusted clients. If set true without such a proxy, per-IP
# rate limits can be trivially spoofed.
APP__SERVER__TRUST_PROXY=false
# IANA timezone for the studio (e.g. Asia/Taipei). Used for day-boundary and
# 24h cancellation-window logic. Invalid values fail at startup rather than
# silently falling back, so bookings cannot land on the wrong day.
APP__SERVER__STUDIO_TIMEZONE=UTC

# Database
APP__DATABASE__URL=postgresql://dreamfly:dreamfly_dev@localhost:5432/dream_fly
APP__DATABASE__MAX_CONNECTIONS=10
APP__DATABASE__MIN_CONNECTIONS=2
# Also set DATABASE_URL for sqlx CLI compatibility
DATABASE_URL=postgresql://dreamfly:dreamfly_dev@localhost:5432/dream_fly

# Redis
APP__REDIS__URL=redis://localhost:6379

# Kafka
APP__KAFKA__BROKERS=localhost:9092
APP__KAFKA__GROUP_ID=dreamfly_backend
APP__KAFKA__ENABLED=false

# JWT
APP__AUTH__JWT_SECRET=change-me-in-production-use-a-long-random-string
APP__AUTH__JWT_ACCESS_EXPIRATION_MINUTES=15
APP__AUTH__JWT_REFRESH_EXPIRATION_DAYS=30

# Google OAuth
APP__AUTH__GOOGLE_CLIENT_ID=
APP__AUTH__GOOGLE_CLIENT_SECRET=
APP__AUTH__GOOGLE_REDIRECT_URL=http://localhost:3000/api/v1/auth/google/callback

# Email (SMTP)
APP__EMAIL__SMTP_HOST=smtp.gmail.com
APP__EMAIL__SMTP_PORT=587
APP__EMAIL__SMTP_USERNAME=
APP__EMAIL__SMTP_PASSWORD=
APP__EMAIL__FROM_EMAIL=info@dreamfly.com.tw
APP__EMAIL__FROM_NAME=Dream Fly 體操館

# Twilio SMS
APP__SMS__TWILIO_ACCOUNT_SID=
APP__SMS__TWILIO_AUTH_TOKEN=
APP__SMS__TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Integration-test overrides (only read by `cargo test`, not by the server)
# -----------------------------------------------------------------------------

# Redis instance used by the integration test harness. Should be a different
# instance OR a different logical db (e.g. `/15`) than the main APP__REDIS__URL
# so test state doesn't mix with local dev state.
TEST_REDIS_URL=redis://localhost:6379/15
